    {
      "factionId": "tiny-blue",
      "name": "Tiny Blue",
      "color": "#4444cc"
    }
  ],
  "pieceDefinitions": [
    {
      "pieceDefId": "infantry",
      "name": "Infantry",
      "type": "unit",
      "defaultCount": 1
