{
  "schemaVersion": "0.1",
  "moduleId": "tiny-module",
  "name": "Tiny Module",
  "version": "0.1.0",
  "engineCompatibility": "0.1",
  "defaultMapId": "tiny-map",
  "defaultScenarioId": "basic",
  "files": {
    "map": "map.json",
